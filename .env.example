# Grafana - defina no Coolify (Environment Variables)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=troque-esta-senha

# Domínio público do Grafana. No Coolify, use a variável mágica
# SERVICE_FQDN_GRAFANA para gerar/rotear o domínio automaticamente.
SERVICE_FQDN_GRAFANA=https://grafana.seu-dominio.com
