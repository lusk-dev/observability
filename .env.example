# Grafana - credenciais (defina no Coolify > Environment Variables)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=troque-esta-senha

# Domínio: NÃO defina SERVICE_* manualmente — o Coolify regenera e sobrescreve.
# Configure em: Configuration > serviço grafana > Domains
#   https://grafana.codewaveds.com.br  (porta 3000)
# Depois do redeploy, o Coolify injeta SERVICE_URL_GRAFANA_3000 automaticamente.
