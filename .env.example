# Grafana - credenciais (defina no Coolify > Environment Variables)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=troque-esta-senha

# Domínio: configure na UI do Coolify no serviço "grafana", porta 3000.
# Use o schema completo: https://grafana.seu-dominio.com
# O Coolify gera SERVICE_URL_GRAFANA_3000 automaticamente a partir do domínio.
